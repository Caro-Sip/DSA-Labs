{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/bin/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "Build all to bin folders",
            "command": "bash",
            "args": [
                "-c",
                "cd ${workspaceFolder} && for dir in lab*/; do mkdir -p \"$dir/bin\"; for file in \"$dir\"*.cpp; do [ -f \"$file\" ] && /usr/bin/g++ -fdiagnostics-color=always -g \"$file\" -o \"$dir/bin/$(basename \"${file%.cpp}\")\" && echo \"Built: $file -> $dir/bin/$(basename \"${file%.cpp}\")\"; done; done"
            ],
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Builds all .cpp files in lab folders to their respective bin directories"
        }
    ],
    "version": "2.0.0"
}